# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL, e.g. https://xxxxx.supabase.co
SUPABASE_URL=
# service_role key (server-side only — never expose this to a browser/client)
SUPABASE_SERVICE_KEY=

# ── Google Drive OAuth (single central account, shared across all clients) ─
# Create these via a Google Cloud project (OAuth client, Desktop app type),
# then generate a refresh token once via the OAuth consent flow.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ── Restaurant Depot receipts filter ────────────────────────────────────────
# Must match one of the option labels in the receipts page date-range <select>.
DATE_RANGE=Last 30 Days – On Demand

# ── Runtime flags ────────────────────────────────────────────────────────
# empty = Playwright's bundled Chromium (default, no extra install needed).
# "chrome" = launch system-installed Google Chrome instead (requires Chrome
# to be installed locally) — a slightly more "real browser" fingerprint, if
# Restaurant Depot's Azure B2C anti-bot checks ever get stricter.
BROWSER_CHANNEL=
# false shows the real browser window (useful for debugging login/selectors)
HEADLESS=true
# true scrapes and parses but skips Drive uploads + Supabase writes
DRY_RUN=false
# set to a restaurant name (must match restaurants.name exactly) to process
# only that one client; leave blank to process all active restaurants
SINGLE_CLIENT=
